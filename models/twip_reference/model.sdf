<?xml version="1.0" encoding="utf-8"?>
<sdf version="1.10">
  <model name="twip_reference">
    <pose>0 0 0 0 0 0</pose>
    <self_collide>false</self_collide>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>

    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>left_wheel_joint</joint_name>
      <topic>/model/tumbller/joint/left_wheel_joint/cmd_vel</topic>
      <use_velocity_commands>true</use_velocity_commands>
      <p_gain>2.5</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.04</d_gain>
      <cmd_max>18.85</cmd_max>
      <cmd_min>-18.85</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>right_wheel_joint</joint_name>
      <topic>/model/tumbller/joint/right_wheel_joint/cmd_vel</topic>
      <use_velocity_commands>true</use_velocity_commands>
      <p_gain>2.5</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.04</d_gain>
      <cmd_max>18.85</cmd_max>
      <cmd_min>-18.85</cmd_min>
    </plugin>

    <link name="chassis">
      <pose>0 0 0.125 0 0 0</pose>
      <inertial>
        <pose>0 0 0.015 0 0 0</pose>
        <mass>0.50</mass>
        <inertia>
          <ixx>0.0020</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0012</iyy>
          <iyz>0</iyz>
          <izz>0.0017</izz>
        </inertia>
      </inertial>

      <collision name="body_collision">
        <pose>0 0 0.015 0 0 0</pose>
        <geometry>
          <box>
            <size>0.090 0.055 0.160</size>
          </box>
        </geometry>
      </collision>
      <visual name="body_visual">
        <pose>0 0 0.015 0 0 0</pose>
        <geometry>
          <box>
            <size>0.090 0.055 0.160</size>
          </box>
        </geometry>
        <material>
          <ambient>0.12 0.15 0.18 1</ambient>
          <diffuse>0.15 0.20 0.24 1</diffuse>
          <specular>0.25 0.25 0.25 1</specular>
        </material>
      </visual>
      <visual name="front_panel">
        <pose>0.048 0 0.030 0 0 0</pose>
        <geometry>
          <box>
            <size>0.006 0.045 0.095</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.48 0.75 1</ambient>
          <diffuse>0.05 0.48 0.75 1</diffuse>
        </material>
      </visual>
      <visual name="com_marker">
        <pose>0 0 0.015 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.010</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.90 0.12 0.08 1</ambient>
          <diffuse>0.90 0.12 0.08 1</diffuse>
        </material>
      </visual>

      <sensor name="imu_sensor" type="imu">
        <pose>0.025 0 0.055 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>200</update_rate>
        <topic>/world/tumbller_lab/model/tumbller/link/chassis/sensor/imu_sensor/imu</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.02</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.02</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.02</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <link name="left_wheel">
      <pose>0 0.082 0.034 0 0 0</pose>
      <inertial>
        <mass>0.050</mass>
        <inertia>
          <ixx>0.000018</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000032</iyy>
          <iyz>0</iyz>
          <izz>0.000018</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.4</mu>
              <mu2>1.4</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.082 0.034 0 0 0</pose>
      <inertial>
        <mass>0.050</mass>
        <inertia>
          <ixx>0.000018</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000032</iyy>
          <iyz>0</iyz>
          <izz>0.000018</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.4</mu>
              <mu2>1.4</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <pose relative_to="chassis">0 0.082 -0.091 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>2.5</effort>
          <velocity>22.0</velocity>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.001</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <pose relative_to="chassis">0 -0.082 -0.091 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>2.5</effort>
          <velocity>22.0</velocity>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.001</friction>
        </dynamics>
      </axis>
    </joint>
  </model>
</sdf>
